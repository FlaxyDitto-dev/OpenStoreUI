<Page
    x:Class="OpenStoreUI.InstalledPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OpenStoreUI.Models">

    <Grid RowDefinitions="Auto, *" Margin="24">
        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="16" Margin="0,0,0,16">
            <TextBlock Text="Installed Packages" Style="{StaticResource TitleTextBlockStyle}"/>
            <Button Content="Refresh" Click="Refresh_Click"/>
        </StackPanel>

        <ScrollViewer Grid.Row="1">
            <GridView ItemsSource="{x:Bind ViewModel.InstalledPackages, Mode=OneWay}">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:AppPackage">
                        <Grid Width="280" Height="130" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Margin="0,0,12,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{x:Bind Name}" Style="{StaticResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1" Text="{x:Bind Version}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}"/>

                            <Button Grid.Row="2" Content="Uninstall" HorizontalAlignment="Right" Click="Uninstall_Click"/>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>
    </Grid>
</Page>