<Window
    x:Class="OpenStoreUI.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="OpenStore - Microsoft Store Alternative">

    <Grid>
        <NavigationView 
            x:Name="NavView" 
            IsSettingsVisible="True" 
            ItemInvoked="NavView_ItemInvoked"
            PaneDisplayMode="Left">
            
            <NavigationView.MenuItems>
                <NavigationViewItem Content="Discover" Tag="discover">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE719;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
                
                <NavigationViewItem Content="Installed Apps" Tag="installed">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE74C;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>

                <NavigationViewItem Content="Updates" Tag="updates">
                    <NavigationViewItem.Icon>
                        <FontIcon Glyph="&#xE777;"/>
                    </NavigationViewItem.Icon>
                </NavigationViewItem>
            </NavigationView.MenuItems>

            <Frame x:Name="ContentFrame" Margin="12,0,12,0"/>
        </NavigationView>
    </Grid>
</Window>