<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs"
     xmlns:ui="http://wixtoolset.org/schemas/v4/wxs/ui">

  <Package Name="OpenStore UI"
           Manufacturer="OpenStore"
           Version="1.0.0.0"
           UpgradeCode="4F392A10-9092-4C98-A122-38B132470129"
           Scope="perMachine">

    <MajorUpgrade DowngradeErrorMessage="A newer version of OpenStore UI is already installed." />
    
    <!-- Setup Wizard UI -->
    <ui:WixUI Id="WixUI_InstallDir" InstallDirectory="INSTALLFOLDER" />

    <!-- Installation Directory in Program Files -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="INSTALLFOLDER" Name="OpenStore UI">
        <Component Id="MainExecutable" Guid="8E1C2893-60B7-44E2-9903-83E88172901B">
          <!-- Main App Executable + Start Menu Shortcut -->
          <File Id="AppExe" Source="publish\OpenStoreUI.exe" KeyPath="yes">
            <Shortcut Id="StartMenuShortcut"
                      Directory="ProgramMenuFolder"
                      Name="OpenStore UI"
                      WorkingDirectory="INSTALLFOLDER"
                      Icon="AppIcon"
                      Advertise="yes" />
          </File>
        </Component>
      </Directory>
    </StandardDirectory>

    <StandardDirectory Id="ProgramMenuFolder" />

    <!-- Automatically harvest all DLLs, resources.pri, and assets into INSTALLFOLDER -->
    <ComponentGroup Id="PublishedFiles" Directory="INSTALLFOLDER">
      <Files Include="publish\**" />
    </ComponentGroup>

    <!-- Main Feature Grouping -->
    <Feature Id="MainFeature" Title="OpenStore UI Application" Level="1">
      <ComponentRef Id="MainExecutable" />
      <ComponentGroupRef Id="PublishedFiles" />
    </Feature>

    <Icon Id="AppIcon" SourceFile="publish\OpenStoreUI.exe" />
  </Package>
</Wix>
