<Page
    x:Class="OpenStoreUI.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:OpenStoreUI.Models">

    <Grid RowDefinitions="Auto, Auto, *, Auto" Margin="24">
        
        <!-- App Title -->
        <TextBlock 
            Grid.Row="0" 
            Text="OpenStore" 
            Style="{StaticResource TitleTextBlockStyle}" 
            Margin="0,0,0,16"/>

        <!-- Search Bar Header -->
        <Grid Grid.Row="1" ColumnDefinitions="*, Auto" Margin="0,0,0,20">
            <TextBox 
                x:Name="SearchBox"
                Grid.Column="0" 
                PlaceholderText="Search apps (e.g., VS Code, Git, VLC, Discord)..."
                Text="{x:Bind ViewModel.SearchQuery, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" 
                KeyDown="SearchBox_KeyDown"
                Margin="0,0,12,0"/>
            
            <Button 
                Grid.Column="1" 
                Content="Search" 
                Style="{StaticResource AccentButtonStyle}" 
                Command="{x:Bind ViewModel.SearchCommand}"/>
        </Grid>

        <!-- Results View -->
        <ScrollViewer Grid.Row="2">
            <GridView ItemsSource="{x:Bind ViewModel.SearchResults, Mode=OneWay}">
                <GridView.ItemTemplate>
                    <DataTemplate x:DataType="models:AppPackage">
                        <Grid Width="280" Height="130" Padding="16" Background="{ThemeResource CardBackgroundFillColorDefaultBrush}" CornerRadius="8" Margin="0,0,12,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{x:Bind Name}" Style="{StaticResource SubtitleTextBlockStyle}" TextTrimming="CharacterEllipsis"/>
                            <TextBlock Grid.Row="1" Text="{x:Bind Id}" Style="{StaticResource CaptionTextBlockStyle}" Foreground="{ThemeResource TextFillColorSecondaryBrush}" TextTrimming="CharacterEllipsis"/>

                            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Install" 
                                        Style="{StaticResource AccentButtonStyle}"
                                        Click="InstallButton_Click"/>
                            </StackPanel>
                        </Grid>
                    </DataTemplate>
                </GridView.ItemTemplate>
            </GridView>
        </ScrollViewer>

        <!-- Status Bar -->
        <Grid Grid.Row="3" Margin="0,16,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBlock Grid.Column="0" Text="{x:Bind ViewModel.StatusMessage, Mode=OneWay}" VerticalAlignment="Center" Style="{StaticResource CaptionTextBlockStyle}"/>
            <ProgressRing Grid.Column="1" IsActive="{x:Bind ViewModel.IsLoading, Mode=OneWay}" Width="20" Height="20"/>
        </Grid>

    </Grid>
</Page>